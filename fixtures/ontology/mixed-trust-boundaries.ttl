<https://understood.app/ontology/axiom/axiom-confirmed-personal> a understood:Axiom ;
  understood:axiomId "axiom-confirmed-personal" ;
  understood:antecedent <https://understood.app/ontology/concept/morning-exercise> ;
  understood:antecedentLabel "Morning exercise" ;
  understood:consequent <https://understood.app/ontology/concept/higher-affect> ;
  understood:consequentLabel "Higher affect" ;
  understood:relationshipType "supports" ;
  understood:confidence "0.72"^^xsd:decimal ;
  understood:evidenceCount 5 ;
  understood:status "confirmed" ;
  understood:scope "personal" ;
  understood:provenanceSource "human_confirmed" .

<https://understood.app/ontology/axiom/axiom-demo-seed> a understood:Axiom ;
