@prefix understood: <https://understood.app/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://understood.app/ontology/concept/source-example> a understood:Concept ;
  understood:label "Source example" .

<https://understood.app/ontology/concept/trust-review> a understood:Concept ;
  understood:label "Trust review" .

<https://understood.app/ontology/axiom/source-self-declared> a understood:Axiom ;
  understood:axiomId "source-self-declared" ;
  understood:antecedent <https://understood.app/ontology/concept/source-example> ;
  understood:consequent <https://understood.app/ontology/concept/trust-review> ;
  understood:relationshipType "supports" ;
  understood:confidence "0.50"^^xsd:decimal ;
  understood:evidenceCount 1 ;
  understood:status "candidate" ;
  understood:scope "personal" ;
  understood:provenanceSource "self_declared" .

<https://understood.app/ontology/axiom/source-ai-proposed> a understood:Axiom ;
  understood:axiomId "source-ai-proposed" ;
  understood:antecedent <https://understood.app/ontology/concept/source-example> ;
  understood:consequent <https://understood.app/ontology/concept/trust-review> ;
  understood:relationshipType "supports" ;
  understood:confidence "0.50"^^xsd:decimal ;
  understood:evidenceCount 1 ;
  understood:status "candidate" ;
  understood:scope "personal" ;
  understood:provenanceSource "ai_proposed" .

<https://understood.app/ontology/axiom/source-entry-extracted> a understood:Axiom ;
  understood:axiomId "source-entry-extracted" ;
  understood:antecedent <https://understood.app/ontology/concept/source-example> ;
  understood:consequent <https://understood.app/ontology/concept/trust-review> ;
  understood:relationshipType "supports" ;
  understood:confidence "0.50"^^xsd:decimal ;
